# ── Painel Admin (/admin) ────────────────────────────────────────────────────
ADMIN_PASSWORD=troque-por-uma-senha-forte

# ── Painel Owner (/owner) ────────────────────────────────────────────────────
OWNER_PASSWORD=troque-por-outra-senha-forte

# ── Supabase ─────────────────────────────────────────────────────────────────
# Painel Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── PIX ──────────────────────────────────────────────────────────────────────
# Chave Pix exibida no card e no modal de contribuição (CPF, e-mail, telefone ou aleatória)
NEXT_PUBLIC_PIX_KEY=

# ── WhatsApp microservice ─────────────────────────────────────────────────────
# URL base do container Docker (sem barra no final)
# Ex: http://123.45.67.89:3100 ou https://whatsapp.meudominio.com
WHATSAPP_SERVICE_URL=http://localhost:3100
# Deve ser idêntico ao API_KEY definido em whatsapp-service/.env
WHATSAPP_SERVICE_KEY=troque-por-uma-chave-secreta-longa
