# ── Admin panel ──────────────────────────────────────────────────────────────
# Senha para acessar /admin — defina algo seguro antes do deploy
ADMIN_PASSWORD=troque-por-uma-senha-forte

# ── Vercel KV ─────────────────────────────────────────────────────────────────
# Cria em vercel.com > seu projeto > Storage > Create Database > KV
# Depois conecte ao projeto e copie as variáveis abaixo (ou configure no painel Vercel)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
