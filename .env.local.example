# Senha do painel admin (escolha uma senha forte)
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Supabase — copie os valores do painel: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Chave Pix exibida no card e no modal de contribuição (opcional)
NEXT_PUBLIC_PIX_KEY=

# Senha do painel owner (seu painel pessoal — use algo diferente do admin)
OWNER_PASSWORD=troque-por-outra-senha-forte

# WhatsApp microservice (deploy em Railway/Render — veja whatsapp-service/)
WHATSAPP_SERVICE_URL=https://seu-servico.railway.app
WHATSAPP_SERVICE_KEY=mesma-chave-do-API_KEY-do-servico
